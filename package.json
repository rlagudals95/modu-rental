{
  "name": "pmf-boilerplate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "verify:full": "pnpm verify && pnpm test:e2e",
    "format": "prettier --write .",
    "ai:sync": "node scripts/sync-ai-context.mjs",
    "prd:new": "node scripts/create-prd.mjs",
    "feature:new": "node scripts/create-feature-from-prd.mjs",
    "work:new": "node scripts/create-work-item.mjs",
    "db:seed": "pnpm --filter @pmf/db seed",
    "db:generate": "pnpm --filter @pmf/db db:generate",
    "db:migrate": "pnpm --filter @pmf/db db:migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.8",
    "prettier": "^3.6.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
