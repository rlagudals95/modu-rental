{
  "manifest_version": 3,
  "name": "RainPulse Nowcast",
  "description": "Minute-level rain start/end countdown on your badge.",
  "version": "0.1.0",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "RainPulse Nowcast",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
